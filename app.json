{
  "expo": {
    "name": "ThanaFit",
    "slug": "thanafit-auth",
    "version": "3.0.7",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "sdkVersion": "53.0.0",
    "scheme": "com.prod.thanafit",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "jsEngine": "hermes",
    "ios": {
      "bundleIdentifier": "com.prod.thanafit",
      "icon": "./assets/icon.png",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ThanaFit uses the microphone to log food and exercise by voice.",
        "NSSpeechRecognitionUsageDescription": "ThanaFit uses speech recognition to turn your voice into text when you log food and exercise by voice.",
        "NSPhotoLibraryUsageDescription": "ThanaFit may access your photo library so you can attach photos to your entries, if you choose."
      },
      "buildNumber": "22"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "1776aca5-7c52-4555-8dc0-4946589c5440"
      },
      "appStoreAppId": "6760138156",
      "playStorePackageId": "com.prod.thanafit"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.prod.thanafit",
      "versionCode": 42
    }
  }
}
