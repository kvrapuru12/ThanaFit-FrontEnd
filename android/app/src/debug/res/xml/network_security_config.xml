<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug builds must reach local Metro over HTTP (10.0.2.2/localhost). -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
